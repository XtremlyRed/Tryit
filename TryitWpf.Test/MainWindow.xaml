<Window x:Class="TryitWpf.Test.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:i="http://schemas.microsoft.com/xaml/behaviors" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:tryit="https://github.com/xtremlyred/Tryit.Wpf" Title="MainWindow" Width="800" Height="450" mc:Ignorable="d">
    <Window.Resources>
        <tryit:BindingAgent x:Key="BindingAgent" DataContext="{Binding}" />
    </Window.Resources>

    <Grid>

        <ListView ItemsSource="{Binding}" VirtualizingPanel.IsContainerVirtualizable="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.ScrollUnit="Item" VirtualizingPanel.VirtualizationMode="Recycling">

            <!--<tryit:AnimationPerform.PerformanceStages>
                <tryit:PerformanceStage TransitionEvent="DataContextChanged">
                    <tryit:TransitionPerformer
                        Target="0"
                        TransitionOn="FadeFrom"
                        Duration="0:0:1" />

                    <tryit:TransitionPerformer
                        Target="100"
                        TransitionOn="TranslateXFrom"
                        Duration="0:0:1" />

                    <tryit:ColorPerformer
                        ColorOn="BackgroundTo"
                        Target="Red"
                        Duration="0:0:1" />
                </tryit:PerformanceStage>
            </tryit:AnimationPerform.PerformanceStages>-->

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Width="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListViewItem}, Path=ActualWidth}" Height="30" Margin="0,3" Background="Transparent" BorderBrush="Red" BorderThickness="0" CornerRadius="4">
                        <tryit:Performance.Stages>

                            <tryit:PerformanceStage StageEvent="Loaded">
                                <tryit:TransitionPerformer Delay="0:0:0" Target="0" TransitionOn="FadeFrom" Duration="0:0:1" />
                                <tryit:TransitionPerformer Delay="0:0:0" Target="50" TransitionOn="TranslateXFrom" Duration="0:0:1" />
                                <tryit:TransitionPerformer Delay="0:0:0" Target="50" TransitionOn="TranslateYFrom" Duration="0:0:1" />
                                <tryit:ColorPerformer ColorOn="BackgroundTo" Delay="0:0:0" Target="DodgerBlue" Duration="0:0:1" />
                            </tryit:PerformanceStage>

                            <tryit:PerformanceStage StageEvent="MouseEnter">
                                <tryit:ColorPerformer ColorOn="BackgroundTo" Delay="0:0:0" Target="DarkRed" Duration="0:0:1" />
                            </tryit:PerformanceStage>

                            <tryit:PerformanceStage StageEvent="MouseLeave">
                                <tryit:ColorPerformer ColorOn="BackgroundTo" Delay="0:0:0" Target="DeepSkyBlue" Duration="0:0:1" />
                            </tryit:PerformanceStage>

                        </tryit:Performance.Stages>

                        <TextBlock Margin="5,0" VerticalAlignment="Center" Text="{Binding}" />
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button HorizontalAlignment="Right" VerticalAlignment="Top" Click="Button_Click" Content="修改数据" />

    </Grid>
</Window>
